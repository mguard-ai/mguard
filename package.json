{
  "name": "bulwark",
  "version": "2.0.0",
  "description": "Production harness for AI agents — behavioral contracts, cryptographic attestation, and multi-witness consensus verification",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bulwark": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "default": "./dist/adapters/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./witness": {
      "types": "./dist/witness/index.d.ts",
      "default": "./dist/witness/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx tests/bulwark.test.ts && tsx tests/witness.test.ts && tsx tests/witness-service.test.ts && tsx tests/witness-consensus.test.ts",
    "test:core": "tsx tests/bulwark.test.ts",
    "demo:support": "tsx examples/customer-support.ts",
    "demo:trading": "tsx examples/trading-bot.ts",
    "demo:review": "tsx examples/code-review.ts",
    "demo:witness": "tsx examples/witness-protocol.ts",
    "test:witness": "tsx tests/witness.test.ts",
    "mcp": "node dist/mcp.js",
    "witness": "tsx src/witness/server.ts",
    "test:service": "tsx tests/witness-service.test.ts",
    "demo:service": "tsx examples/witness-service.ts",
    "demo:consensus": "tsx examples/witness-consensus.ts",
    "test:consensus": "tsx tests/witness-consensus.test.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "harness",
    "safety",
    "contracts",
    "guardrails",
    "drift-detection",
    "budget",
    "compliance",
    "openai",
    "anthropic",
    "langchain",
    "vercel-ai",
    "mcp",
    "attestation",
    "witness",
    "consensus",
    "ed25519",
    "bft",
    "eu-ai-act"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
